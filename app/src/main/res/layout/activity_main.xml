<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text=""
        android:textColor="#94A3B8"
        android:textSize="24sp"
        android:padding="8dp"
        android:maxLines="2" />

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="@string/display_zero"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:maxLines="2" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="7"
        android:useDefaultMargins="true">

        <Button
            android:id="@+id/btnSin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/sin"
            android:textSize="18sp"
            android:backgroundTint="#334155"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/cos"
            android:textSize="18sp"
            android:backgroundTint="#334155"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnTan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/tan"
            android:textSize="18sp"
            android:backgroundTint="#334155"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnLog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/log"
            android:textSize="18sp"
            android:backgroundTint="#334155"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPower"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/power"
            android:textSize="22sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnOpen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/open_parenthesis"
            android:textSize="22sp"
            android:backgroundTint="#475569"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/close_parenthesis"
            android:textSize="22sp"
            android:backgroundTint="#475569"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/clear"
            android:textSize="22sp"
            android:backgroundTint="#DC2626"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/seven"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/eight"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/nine"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnDivide"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/divide"
            android:textSize="24sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/four"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/five"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/six"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnMultiply"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/multiply"
            android:textSize="24sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/one"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/two"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/three"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/minus"
            android:textSize="24sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/zero"
            android:textSize="24sp"
            android:backgroundTint="#1E293B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnDot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/dot"
            android:textSize="24sp"
            android:backgroundTint="#475569"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnEquals"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/equals"
            android:textSize="24sp"
            android:backgroundTint="#16A34A"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPlus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/plus"
            android:textSize="24sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF" />

    </GridLayout>

</LinearLayout>